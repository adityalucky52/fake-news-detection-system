// Prisma Schema — Fake News Detection System
// ORM: Prisma 7 | Database: PostgreSQL (Neon)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  user
  admin
}

enum Label {
  REAL
  FAKE
  MISLEADING
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  role        Role         @default(user)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  predictions Prediction[]

  @@map("users")
}

model Prediction {
  id          String   @id @default(cuid())
  text        String
  label       Label
  confidence  Float
  explanation String?
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("predictions")
}
